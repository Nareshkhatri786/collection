// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  STAFF
  DEVELOPER
}

enum ProjectStatus {
  UNDER_CONSTRUCTION
  READY
}

enum UnitStatus {
  AVAILABLE
  BOOKED
  REGISTERED
}

enum RegistryStatus {
  PENDING
  IN_PROGRESS
  DONE
}

enum PaymentStatus {
  PENDING
  PARTIAL
  RECEIVED
  OVERDUE
}

enum PaymentMode {
  CHEQUE
  NEFT
  CASH
  UPI
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(STAFF)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  projectAccess    UserProjectAccess[]
  auditLogs        AuditLog[]
  labourPayments   LabourPayment[]
  developerProject Project[]           @relation("DeveloperUser")
  createdDeals     Deal[]              @relation("DealCreatedBy")

  @@map("users")
}

model UserProjectAccess {
  id        Int     @id @default(autoincrement())
  userId    Int
  projectId Int

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@map("user_project_access")
}

model Project {
  id                 Int           @id @default(autoincrement())
  name               String
  developerName      String
  location           String
  status             ProjectStatus @default(UNDER_CONSTRUCTION)
  maintenanceDeposit Decimal       @db.Decimal(12, 2) @default(0)
  possessionDate     DateTime?
  developerUserId    Int?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  developerUser User?               @relation("DeveloperUser", fields: [developerUserId], references: [id])
  unitTypes     UnitType[]
  units         Unit[]
  deals         Deal[]
  userAccess    UserProjectAccess[]

  @@map("projects")
}

model UnitType {
  id        Int     @id @default(autoincrement())
  projectId Int
  typeName  String
  basePrice Decimal @db.Decimal(12, 2)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  units   Unit[]

  @@map("unit_types")
}

model Unit {
  id         Int        @id @default(autoincrement())
  projectId  Int
  unitTypeId Int?
  unitNumber String
  floor      Int?
  carpetArea Decimal?   @db.Decimal(10, 2)
  status     UnitStatus @default(AVAILABLE)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  unitType UnitType? @relation(fields: [unitTypeId], references: [id])
  deal     Deal?

  @@unique([projectId, unitNumber])
  @@map("units")
}

model Client {
  id        Int      @id @default(autoincrement())
  name      String
  mobile    String
  email     String?
  pan       String?
  aadhar    String?
  address   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deals Deal[]

  @@map("clients")
}

model Deal {
  id                 Int            @id @default(autoincrement())
  projectId          Int
  unitId             Int            @unique
  clientId           Int
  dealAmount         Decimal        @db.Decimal(12, 2)
  stampDuty          Decimal        @db.Decimal(12, 2)
  gstRate            Decimal        @db.Decimal(5, 2)
  gstAmount          Decimal        @db.Decimal(12, 2)
  maintenanceDeposit Decimal        @db.Decimal(12, 2)
  subTotal           Decimal        @db.Decimal(12, 2)
  ownMargin          Decimal        @db.Decimal(12, 2)
  loanAmount         Decimal        @db.Decimal(12, 2)
  loanBank           String?
  extraWork          Decimal        @db.Decimal(12, 2) @default(0)
  otherCharges       Decimal        @db.Decimal(12, 2) @default(0)
  totalCash          Decimal        @db.Decimal(12, 2) @default(0)
  possessionDate     DateTime?
  registryTargetDate DateTime?
  registryStatus     RegistryStatus @default(PENDING)
  registryDoneDate   DateTime?
  gstOverridden      Boolean        @default(false)
  notes              String?        @db.Text
  createdBy          Int?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  project        Project          @relation(fields: [projectId], references: [id])
  unit           Unit             @relation(fields: [unitId], references: [id])
  client         Client           @relation(fields: [clientId], references: [id])
  createdByUser  User?            @relation("DealCreatedBy", fields: [createdBy], references: [id])
  marginSchedule MarginSchedule[]
  loanSchedule   LoanSchedule[]
  cashSchedule   CashSchedule[]
  labourPayments LabourPayment[]

  @@map("deals")
}

model MarginSchedule {
  id             Int           @id @default(autoincrement())
  dealId         Int
  description    String
  dueDate        DateTime
  amount         Decimal       @db.Decimal(12, 2)
  receivedDate   DateTime?
  receivedAmount Decimal?      @db.Decimal(12, 2)
  paymentMode    PaymentMode?
  receiptNumber  String?
  status         PaymentStatus @default(PENDING)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@map("margin_schedule")
}

model LoanSchedule {
  id               Int           @id @default(autoincrement())
  dealId           Int
  stageDescription String
  expectedDate     DateTime
  amount           Decimal       @db.Decimal(12, 2)
  receivedDate     DateTime?
  receivedAmount   Decimal?      @db.Decimal(12, 2)
  status           PaymentStatus @default(PENDING)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@map("loan_schedule")
}

model CashSchedule {
  id             Int           @id @default(autoincrement())
  dealId         Int
  description    String
  dueDate        DateTime
  amount         Decimal       @db.Decimal(12, 2)
  receivedDate   DateTime?
  receivedAmount Decimal?      @db.Decimal(12, 2)
  status         PaymentStatus @default(PENDING)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@map("cash_schedule")
}

model LabourPayment {
  id          Int      @id @default(autoincrement())
  dealId      Int
  paidDate    DateTime
  amount      Decimal  @db.Decimal(12, 2)
  description String?
  paidBy      Int?
  createdAt   DateTime @default(now())

  deal       Deal  @relation(fields: [dealId], references: [id], onDelete: Cascade)
  paidByUser User? @relation(fields: [paidBy], references: [id])

  @@map("labour_payments")
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int?
  entityType String
  entityId   Int
  action     String
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}
